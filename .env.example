# JWT — algoritmo RS256
JWT_EXPIRATION_HOURS=1
JWT_PRIVATE_KEY_PATH=/var/task/certs/private.pem
JWT_PUBLIC_KEY_PATH=/var/task/certs/public.pem

# Fonte de usuários — SSM Parameter Store (padrão) ou JSON inline
USERS_PARAM_NAME=/lambda-authorize/users
# USERS_LIST=[{"name":"...","email":"...","senha":"<md5>"}]  # substitui o SSM

# Para apontar para LocalStack local:
# AWS_ENDPOINT_URL=http://localstack:4566

# Credenciais AWS (use credenciais reais em produção)
AWS_DEFAULT_REGION=us-east-1
AWS_ACCESS_KEY_ID=your-access-key-id
AWS_SECRET_ACCESS_KEY=your-secret-access-key
