# Segredo para assinar os tokens JWT (troque em produção)
JWT_SECRET=change-me-in-production
JWT_EXPIRATION_HOURS=1

# Lista de usuários em JSON.
# O campo "senha" deve ser o hash MD5 da senha em texto plano.
# Exemplo: MD5("minha_senha") — obtenha com: echo -n "minha_senha" | md5sum
USERS_LIST=[{"name":"Exemplo Usuario","email":"usuario@exemplo.com","senha":"<hash-md5-da-senha>"}]

# Quando USERS_LIST não estiver definido, a Lambda busca no SSM Parameter Store
USERS_PARAM_NAME=/lambda-authorize/users

# Credenciais AWS (fictícias para testes locais; use credenciais reais em produção)
AWS_DEFAULT_REGION=us-east-1
AWS_ACCESS_KEY_ID=dummy
AWS_SECRET_ACCESS_KEY=dummy
